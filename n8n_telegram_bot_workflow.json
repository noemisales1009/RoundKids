      "id": "d7d8835c-363b-40f8-a8ca-816c7cb60221",
      "name": "Carregar Memoria",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [768, 832],
      "credentials": {
        "supabaseApi": {
          "id": "13fzGTtAnxtag1Iq",
          "name": "Supabase CucaDigital"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const allItems = $('Carregar Memoria').all().map(i => i.json);\nconst userMsg = $('Combinar Mensagens').first().json.text;\nconst chat_id = $('Combinar Mensagens').first().json.chat_id;\nconst user_id = $('Verificar Usuario').first().json.user_id || '';\n\nconst lastWithPending = allItems.find(h => h.pending_action);\nconst pendingAction = lastWithPending?.pending_action || null;\nconst lastPatientId = allItems.find(h => h.patient_id)?.patient_id || null;\nconst lastPatientName = allItems.find(h => h.patient_name)?.patient_name || null;\n\nconst history = allItems\n  .reverse()\n  .filter(h => h.role && h.content)\n  .map(h => ({ role: h.role, content: h.content }));\n\nhistory.push({ role: 'user', content: userMsg });\n\nreturn [{\n  json: {\n    history, chat_id, user_id, userMsg,\n    pendingAction, lastPatientId, lastPatientName\n  }\n}];"
      },
      "id": "d891ada2-4df0-49dd-be14-e5a3c6bbb4f8",
      "name": "Montar Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [992, 832]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $input.first().json;\nconst userMsg = ctx.userMsg.toLowerCase().trim();\nconst pending = ctx.pendingAction;\n\nif (pending) {\n  if (['sim', 'confirmar', 'ok', 'confirma', 's'].includes(userMsg)) {\n    return [{ json: { ...ctx, intent: 'confirm' } }];\n  }\n  if (['nao', 'cancelar', 'cancela', 'n'].includes(userMsg)) {\n    return [{ json: { ...ctx, intent: 'cancel' } }];\n  }\n}\n\nreturn [{ json: { ...ctx, intent: 'process' } }];"
      },
      "id": "01bd6e99-6e09-463d-b22c-6f9c46fb1360",
      "name": "Verificar Pendencia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1216, 832]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.intent }}", "rightValue": "confirm", "operator": { "type": "string", "operation": "equals" } }
                ]
              },
              "renameOutput": "Confirmar"
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.intent }}", "rightValue": "cancel", "operator": { "type": "string", "operation": "equals" } }
                ]
              },
              "renameOutput": "Cancelar"
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.intent }}", "rightValue": "process", "operator": { "type": "string", "operation": "equals" } }
                ]
              },
              "renameOutput": "Processar"
            }
          ]
        },
        "options": {}
      },
