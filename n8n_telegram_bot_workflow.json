        "jsCode": "const item = $input.first().json;\nconst responseText = item.output || item.text || item.response || 'Sem resposta.';\nconst ctx = $('Verificar Pendencia').first().json;\n\nreturn [{\n  json: {\n    responseText,\n    patientId: ctx.lastPatientId,\n    patientName: ctx.lastPatientName,\n    pendingAction: null\n  }\n}];"
