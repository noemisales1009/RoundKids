      "name": "Supabase - Cadastrar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1648, 624]
    },
    {
      "parameters": {
        "jsCode": "const pending = $('Verificar Pendencia').first().json.pendingAction;\nconst result = $input.first().json;\nlet text = result.error\n  ? 'Erro ao cadastrar: ' + result.error\n  : 'Registrado com sucesso!\\n\\n' + (pending.confirmMessage || 'Dados salvos.');\nreturn [{ json: { responseText: text, pendingAction: null } }];"
      },
      "id": "e6439e39-598b-4af4-89b1-26b304d2e809",
      "name": "Sucesso Cadastro",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1872, 624]
