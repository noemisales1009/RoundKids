# ============================================================
# RoundKids — configuração de servidor (Hostinger / Apache / LiteSpeed)
# Este arquivo é copiado automaticamente para dist/ a cada `npm run build`.
# Substitui o que o vercel.json faria (o vercel.json é ignorado na Hostinger).
# ============================================================

# ------------------------------------------------------------
# 1) Roteamento SPA (React Router)
# Faz o servidor entregar index.html para rotas do app (ex.: /dashboard),
# senão dar F5 numa rota interna resulta em 404.
# >>> SE você JÁ tem um .htaccess funcionando no servidor com regras de
#     rewrite, NÃO sobrescreva: copie só o bloco 2 (headers) pra ele. <<<
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Não reescrever arquivos/pastas que existem de verdade
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Todo o resto -> index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ------------------------------------------------------------
# 2) Headers de segurança
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # CSP em modo REPORT-ONLY: apenas reporta violações no console (F12),
  # NÃO bloqueia nada. Depois de validar que o app funciona sem violações,
  # troque "Content-Security-Policy-Report-Only" por "Content-Security-Policy"
  # para ligar o bloqueio de verdade.
  Header set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://aistudiocdn.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://aistudiocdn.com https://esm.sh; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
</IfModule>

# ------------------------------------------------------------
# 3) Cache: assets com hash no nome podem ser cacheados pra sempre;
# o index.html nunca (pra sempre pegar a versão nova após deploy).
# ------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
